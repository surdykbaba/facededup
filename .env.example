# Application
APP_NAME=FaceDedup API
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1

# Database
DATABASE_URL=postgresql+asyncpg://facededup:changeme@postgres:5432/facededup
DB_USER=facededup
DB_PASSWORD=changeme
DB_NAME=facededup
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://redis:6379/0

# Security - comma-separated API keys
API_KEYS=your-api-key-here

# Rate Limiting
RATE_LIMIT_REQUESTS=6000
RATE_LIMIT_WINDOW_SECONDS=60
BATCH_RATE_LIMIT_REQUESTS=1000
BATCH_RATE_LIMIT_WINDOW_SECONDS=60
BATCH_MAX_IMAGES=500
BATCH_MAX_EMBEDDINGS=5000

# Face Detection
FACE_MODEL_NAME=buffalo_l
FACE_DET_SIZE=640,640
SIMILARITY_THRESHOLD=0.6

# Storage
IMAGE_STORAGE_PATH=/data/images
MAX_IMAGE_SIZE_MB=10

# Server
WORKERS=2
